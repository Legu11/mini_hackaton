// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  role Role @default(TESTEUR)
  active Boolean @default(true)
  tickets_created Ticket[]
  packets_created Packet[]
}

model Ticket {
  id Int @id @default(autoincrement())
  title String
  description String?
  statut Statut @default(EN_COURS)
  priorite Priorite @default(MOYENNE)
  creationDate DateTime @default(now())
  lastUpdateDate DateTime @updatedAt
  authorId Int
  author User @relation(fields: [authorId], references: [id])
  packetId Int
  packet Packet @relation(fields: [packetId], references: [id])
}

model Packet {
  id Int @id @default(autoincrement())
  title String
  description String?
  authorId Int
  statut Statut @default(EN_COURS)
  creationDate DateTime @default(now())
  lastUpdateDate DateTime @updatedAt
  author User @relation(fields: [authorId], references: [id])
  tickets Ticket[]
}

enum Statut {
  EN_COURS
  A_FAIRE
  RESOLU
  EN_REVUE
  }

enum Role {
  ADMIN
  CHEF_PROJET
  DEV
  TESTEUR
}

enum Priorite {
  CRITIQUE
  HAUTE
  MOYENNE
}